# Compose settings only (no secrets — those go in app.env).
# Must match the tag used in: docker build -t survivor_soul_rpg:v1 .

IMAGE_NAME=survivor_soul_rpg
IMAGE_TAG=v1
HOST_PORT=5001
PULL_POLICY=never

# For GHCR deploy (docker compose -f docker-compose.ghcr.yml):
# GITHUB_REPOSITORY=ygmrtm/survivor_soul_rpg
