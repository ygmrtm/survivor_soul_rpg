# Flask
FLASK_ENV=production
PORT=5000

# Notion
NOTION_API_KEY=
NOTION_DBID_CHARS=
NOTION_PGID_HABIT=
NOTION_DBID_HABIT=
NOTION_DBID_ABILI=
NOTION_DBID_DLYLG=
NOTION_DBID_ADVEN=
NOTION_DBID_EPICS=
NOTION_DBID_BIKES=
NOTION_DBID_STENC=
NOTION_DBID_CODIN=
NOTION_DBID_WATCH=

# Redis Cloud
REDIS_URL=redis://default:password@host.cloud.redislabs.com:port

# Production host port mapping (docker-compose only)
HOST_PORT=5000

# Image tag used by docker-compose.prod.yml
APP_VERSION=latest

# GitHub repo for image name (defaults to ygmrtm/survivor_soul_rpg)
GITHUB_REPOSITORY=ygmrtm/survivor_soul_rpg
